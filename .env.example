# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_string_in_production
JWT_EXPIRE=30d

# ── Cloudinary (sign up free at cloudinary.com) ───────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Razorpay (sign up at razorpay.com) ────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Email (Gmail SMTP — enable "App Password") ────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=Saanjh Boutique <noreply@saanjhboutique.com>

# ── App URLs ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

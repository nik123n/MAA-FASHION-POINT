# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Saanjh Boutique <noreply@saanjhboutique.com>

# Frontend URL(s) for CORS - comma separated
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173,https://nik123n.github.io

# Firebase Admin
# Use ONE of these:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
FIREBASE_SERVICE_ACCOUNT_PATH=C:\path\to\firebase-admin.json

# Admin
ADMIN_EMAIL=admin@saanjhboutique.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=MAA Admin

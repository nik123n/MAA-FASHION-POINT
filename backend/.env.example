# ============================================================
# MAA Fashion Point — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — only .env.example

# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Firebase Admin SDK ───────────────────────────────────
# Option 1: Paste the full service account JSON string (Base64 or raw)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option 2: Path to service account JSON file (local dev only)
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-admin.json

# ─── Razorpay ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# ⚠️ IMPORTANT: This is a SEPARATE secret set in Razorpay Dashboard > Webhooks
# It is NOT the same as RAZORPAY_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Email (Gmail SMTP) ────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=MAA Fashion Point <noreply@maafashionpoint.com>

# ─── Frontend URL(s) for CORS ─────────────────────────────
# Comma-separated list of allowed origins
FRONTEND_URL=http://localhost:5173
# ADDITIONAL_FRONTEND_URLS=https://your-app.vercel.app,https://nik123n.github.io

# ─── Admin User (for ensure-admin script only) ────────────
# Never used at runtime — only for the CLI script
ADMIN_EMAIL=maafashtionpoint@gmail.com

# ─── Upstash Redis (optional caching) ─────────────────────
# Get free credentials at upstash.com
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ─── Sentry (error tracking) ──────────────────────────────
# Get DSN at sentry.io — leave empty to disable
SENTRY_DSN=

# ─── Cloudinary (image uploads) ───────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================================
# REMOVED (no longer needed):
#   JWT_SECRET       — Firebase handles auth tokens
#   JWT_EXPIRE       — Firebase handles token expiry
#   ADMIN_PASSWORD   — Never store passwords in env
# ============================================================
